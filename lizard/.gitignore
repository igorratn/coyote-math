# macOS
.DS_Store

# Screenshots / scratch images (not for git)
screenshots/

# Raw SA dumps (disposable — data embedded in task files)
scrapes/

# Job 0 inbound queue (operational state, drained by Job 0 actor)
queue/

# Intermediate reviewer + skeleton outputs (regeneratable from scrapes)
tasks/review1/
tasks/review2/
tasks/skeleton/

# Temp/scratch
temp_*
*.tmp
*.bak

# OS / editor cruft
Thumbs.db
*.swp
*~
.idea/
.vscode/

# Crop/verify scratch (image scratchpads)
.crops/
tmp_crops/
tmp_verify/
work_tmp/

# Retired stage3 output
stage3/

# Local user config
.claude/settings.local.json

# Secrets / env
.env
.env.*
!.env.example

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node
node_modules/
